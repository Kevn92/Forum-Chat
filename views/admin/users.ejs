<%- include('../partials/header') %>

<div class="container-fluid admin-panel-container">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="admin-title"><i class="bi bi-shield-lock"></i> Admin Panel - User Management</h2>
                <a href="/forums" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Back to Forums
                </a>
            </div>

            <% if (typeof success !== 'undefined' && success && success.length > 0) { %>
                <script>
                    document.addEventListener('DOMContentLoaded', function() {
                        Swal.fire({
                            icon: 'success',
                            title: 'Berhasil',
                            text: '<%= success[0] %>'
                        });
                    });
                </script>
            <% } %>

            <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
                <script>
                    document.addEventListener('DOMContentLoaded', function() {
                        Swal.fire({
                            icon: 'error',
                            title: 'Gagal',
                            text: '<%= error[0] %>'
                        });
                    });
                </script>
            <% } %>

            <!-- Users Table -->
            <div class="card shadow admin-card">
                <div class="card-header admin-card-header">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="bi bi-people"></i> All Users (<%= totalUsersCount %>)</h5>
                        <form action="/admin/users" method="GET" class="d-flex">
                            <div class="input-group input-group-sm">
                                <input type="text" class="form-control" name="search"
                                       placeholder="Search by username, nickname, or phone..."
                                       value="<%= typeof search !== 'undefined' ? search || '' : '' %>">
                                <button class="btn btn-light" type="submit">
                                    <i class="bi bi-search"></i> Search
                                </button>
                                <% if (typeof search !== 'undefined' && search) { %>
                                    <a href="/admin/users" class="btn btn-outline-light">
                                        <i class="bi bi-x-circle"></i> Clear
                                    </a>
                                <% } %>
                            </div>
                        </form>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover table-striped mb-0 admin-table">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Username</th>
                                    <th>Nickname</th>
                                    <th>Phone</th>
                                    <th>Role</th>
                                    <th>Forums</th>
                                    <th>Messages</th>
                                    <th>Joined</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (users.length === 0) { %>
                                    <tr>
                                        <td colspan="9" class="text-center text-muted py-4">
                                            <i class="bi bi-search" style="font-size: 2rem;"></i>
                                            <p class="mt-2">No users found matching "<%= search %>"</p>
                                        </td>
                                    </tr>
                                <% } %>

                                <% users.forEach((user, index) => { %>
                                    <tr class="<%= user.id === userId ? 'table-primary' : '' %> <%= search && index < 3 ? 'table-warning' : '' %>">
                                        <td><%= user.id %></td>
                                        <td>
                                            <img src="<%= user.profile_picture || '/images/default-profile.png' %>" alt="Profile"
                                                 class="rounded-circle me-2 admin-profile-pic" style="width: 30px; height: 30px; object-fit: cover;">
                                            <strong class="searchable username-text"><%= user.username || 'No Username' %></strong>
                                            <% if (user.id === userId) { %>
                                                <span class="badge bg-info">You</span>
                                            <% } %>
                                        </td>
                                        <td>
                                            <span class="nickname-text searchable" style="color: <%= user.nametag_color || 'var(--text-primary)' %>; font-weight: 500;">
                                                <%= user.nickname || user.username || 'N/A' %>
                                            </span>
                                        </td>
                                        <td class="searchable phone-text"><%= user.phone || '-' %></td>
                                        <td>
                                            <span class="badge bg-<%= user.role === 'admin' ? 'danger' : 'primary' %>">
                                                <i class="bi bi-<%= user.role === 'admin' ? 'shield' : 'person' %>"></i>
                                                <%= user.role %>
                                            </span>
                                        </td>
                                        <td>
                                            <span class="badge bg-info"><%= user.forumCount %></span>
                                        </td>
                                        <td>
                                            <span class="badge bg-success"><%= user.messageCount %></span>
                                        </td>
                                        <td>
                                            <small class="joined-date"><%= new Date(user.created_at).toLocaleDateString('id-ID') %></small>
                                        </td>
                                        <td>
                                            <% if (user.id !== userId) { %>
                                                <button class="btn btn-sm btn-warning text-dark"
                                                        onclick="confirmResetPassword('<%- user.username.replace(/'/g, "\\'") %>', <%= user.id %>)">
                                                    <i class="bi bi-key"></i> Reset
                                                </button>
                                                <form id="reset-password-form-<%= user.id %>"
                                                      action="/admin/users/reset-password/<%= user.id %>"
                                                      method="POST" class="d-none">
                                                </form>

                                                <button class="btn btn-sm btn-danger ms-1"
                                                        onclick="confirmDeleteUser('<%- user.username.replace(/'/g, "\\'") %>', <%= user.id %>)">
                                                    <i class="bi bi-trash"></i> Delete
                                                </button>
                                                <form id="delete-user-form-<%= user.id %>"
                                                      action="/admin/users/delete/<%= user.id %>"
                                                      method="POST" class="d-none">
                                                </form>
                                            <% } else { %>
                                                <span class="text-muted small">-</span>
                                            <% } %>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                    
                    <!-- Pagination -->
                    <% if (totalPages > 1) { %>
                        <div class="pagination-container">
                            <nav aria-label="Users pagination">
                                <ul class="pagination custom-pagination justify-content-center mb-0">
                                <!-- Previous Button -->
                                <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                                    <a class="page-link" href="<%= currentPage === 1 ? '#' : '?page=' + (currentPage - 1) + (search ? '&search=' + encodeURIComponent(search) : '') %>" tabindex="-1">
                                        <i class="bi bi-chevron-left"></i> Previous
                                    </a>
                                </li>
                                
                                <!-- Page Numbers -->
                                <% 
                                let startPage = Math.max(1, currentPage - 2);
                                let endPage = Math.min(totalPages, currentPage + 2);
                                
                                if (startPage > 1) { %>
                                    <li class="page-item"><a class="page-link" href="?page=1<%= search ? '&search=' + encodeURIComponent(search) : '' %>">1</a></li>
                                    <% if (startPage > 2) { %>
                                        <li class="page-item disabled"><span class="page-link">...</span></li>
                                    <% } %>
                                <% } %>

                                <% for(let i = startPage; i <= endPage; i++) { %>
                                    <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                                        <a class="page-link" href="?page=<%= i %><%= search ? '&search=' + encodeURIComponent(search) : '' %>"><%= i %></a>
                                    </li>
                                <% } %>

                                <% if (endPage < totalPages) { %>
                                    <% if (endPage < totalPages - 1) { %>
                                        <li class="page-item disabled"><span class="page-link">...</span></li>
                                    <% } %>
                                    <li class="page-item"><a class="page-link" href="?page=<%= totalPages %><%= search ? '&search=' + encodeURIComponent(search) : '' %>"><%= totalPages %></a></li>
                                <% } %>

                                <!-- Next Button -->
                                <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                                    <a class="page-link" href="<%= currentPage === totalPages ? '#' : '?page=' + (currentPage + 1) + (search ? '&search=' + encodeURIComponent(search) : '') %>">
                                        Next <i class="bi bi-chevron-right"></i>
                                    </a>
                                </li>
                            </ul>
                            </nav>
                        </div>
                    <% } %>
                </div>
            </div>

            <!-- Quick Stats -->
            <div class="row mt-4">
                <div class="col-md-4">
                    <div class="card shadow-sm admin-stat-card">
                        <div class="card-body text-center">
                            <h3 class="admin-stat-number text-primary"><%= totalUsersCount %></h3>
                            <p class="admin-stat-label mb-0">Total Users</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card shadow-sm admin-stat-card">
                        <div class="card-body text-center">
                            <h3 class="admin-stat-number text-success"><%= totalRegularCount %></h3>
                            <p class="admin-stat-label mb-0">Regular Users</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card shadow-sm admin-stat-card">
                        <div class="card-body text-center">
                            <h3 class="admin-stat-number text-danger"><%= totalAdminCount %></h3>
                            <p class="admin-stat-label mb-0">Admins</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
function confirmDeleteUser(username, userId) {
    Swal.fire({
        title: 'Delete User?',
        html: `Are you sure you want to delete user <strong>"${username}"</strong>?<br><br>
               <div class="text-start">
               This will permanently delete:<br>
               • The user account<br>
               • All messages by this user<br>
               • All forums created by this user<br><br>
               <span class="text-danger fw-bold">This action cannot be undone!</span>
               </div>`,
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#dc3545',
        cancelButtonColor: '#6c757d',
        confirmButtonText: 'Yes, delete user',
        cancelButtonText: 'Cancel',
        background: document.body.classList.contains('theme-dark') ? '#2d2d2d' : '#ffffff',
        color: document.body.classList.contains('theme-dark') ? '#ffffff' : '#1f2937'
    }).then((result) => {
        if (result.isConfirmed) {
            document.getElementById('delete-user-form-' + userId).submit();
        }
    });
}

function confirmResetPassword(username, userId) {
    Swal.fire({
        title: 'Reset Password?',
        html: `Are you sure you want to reset password for user <strong>"${username}"</strong>?<br><br>
               The password will be reset to: <span class="text-primary fw-bold" style="font-size: 1.2rem;">Jumanji99</span>`,
        icon: 'question',
        showCancelButton: true,
        confirmButtonColor: '#ffc107',
        cancelButtonColor: '#6c757d',
        confirmButtonText: '<span class="text-dark">Yes, reset it</span>',
        cancelButtonText: 'Cancel',
        background: document.body.classList.contains('theme-dark') ? '#2d2d2d' : '#ffffff',
        color: document.body.classList.contains('theme-dark') ? '#ffffff' : '#1f2937'
    }).then((result) => {
        if (result.isConfirmed) {
            document.getElementById('reset-password-form-' + userId).submit();
        }
    });
}

function highlightText(text, search) {
    if (!search || !text) return text;
    var regex = new RegExp('(' + search.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'gi');
    return text.toString().replace(regex, '<mark class="bg-warning text-dark">$1</mark>');
}

// Auto-highlight search results on page load
document.addEventListener('DOMContentLoaded', function() {
    var search = '<%= search %>';
    if (search) {
        var cells = document.querySelectorAll('.searchable');
        cells.forEach(function(cell) {
            cell.innerHTML = highlightText(cell.textContent, search);
        });
    }
});
</script>

<%- include('../partials/footer') %>
