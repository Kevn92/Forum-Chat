<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Forum Chat</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        html, body {
            height: 100%;
            margin: 0;
            padding: 0;
        }
    </style>
</head>
<body class="m-0 p-0 theme-<%= theme %>">
<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <h2><i class="bi bi-box-arrow-in-right"></i> Welcome Back</h2>
            <p>Sign in to your account to continue</p>
        </div>

        <% if (error) { %>
        <div class="auth-alert">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <div>
                <strong>Error:</strong> <%= error %>
            </div>
        </div>
        <% } %>
        
        <form action="/auth/login" method="POST">
            <div class="auth-form-group">
                <label for="username">
                    <i class="bi bi-person-fill"></i> Username
                </label>
                <input type="text" class="auth-input" id="username" name="username" 
                       placeholder="Enter your username" required autofocus>
            </div>

            <div class="auth-form-group">
                <label for="password">
                    <i class="bi bi-lock-fill"></i> Password
                </label>
                <div class="position-relative">
                    <input type="password" class="auth-input" id="password" name="password" 
                           placeholder="Enter your password" required style="padding-right: 40px; width: 100%;">
                    <i class="bi bi-eye-slash toggle-password" id="togglePassword" style="position: absolute; right: 15px; top: 50%; transform: translateY(-50%); cursor: pointer; color: var(--text-color);"></i>
                </div>
            </div>

            <button type="submit" class="auth-btn">
                <i class="bi bi-box-arrow-in-right"></i> Sign In
            </button>
        </form>

        <div class="auth-divider">
            <span>OR</span>
        </div>

        <div class="auth-footer">
            Don't have an account? 
            <a href="/auth/register">Create one now</a>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    const togglePassword = document.querySelector('#togglePassword');
    const password = document.querySelector('#password');

    togglePassword.addEventListener('click', function (e) {
        const type = password.getAttribute('type') === 'password' ? 'text' : 'password';
        password.setAttribute('type', type);
        this.classList.toggle('bi-eye');
        this.classList.toggle('bi-eye-slash');
    });

    const urlParams = new URLSearchParams(window.location.search);
    const alertParam = urlParams.get('alert');

    if (alertParam) {
        let swalOptions = {};
        if (alertParam === 'login_failed') {
            swalOptions = {
                icon: 'error',
                title: 'Login Gagal',
                text: 'Login gagal, periksa kembali username dan password'
            };
        } else if (alertParam === 'logout_success') {
            swalOptions = {
                icon: 'success',
                title: 'Berhasil Logout',
                text: 'Berhasil logout'
            };
        } else if (alertParam === 'register_success') {
            swalOptions = {
                icon: 'success',
                title: 'Registrasi Berhasil',
                text: 'Akun ini berhasil dibuat'
            };
        }
        
        if (Object.keys(swalOptions).length > 0) {
            Swal.fire(swalOptions).then(() => {
                urlParams.delete('alert');
                const newUrl = window.location.pathname + (urlParams.toString() ? '?' + urlParams.toString() : '');
                window.history.replaceState(null, '', newUrl);
            });
        }
    }
</script>
</body>
</html>